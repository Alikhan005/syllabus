# Django core
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY
DJANGO_DEBUG=False

# Domain / hosts
DJANGO_ALLOWED_HOSTS=syllabus.example.com,www.syllabus.example.com
ALLOWED_HOSTS=syllabus.example.com,www.syllabus.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://syllabus.example.com,https://www.syllabus.example.com
CSRF_TRUSTED_ORIGINS=https://syllabus.example.com,https://www.syllabus.example.com

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://db_user:db_password@127.0.0.1:5432/almau_syllabus
DJANGO_USE_DATABASE_URL=True

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=AlmaU Syllabus <noreply@example.com>
SERVER_EMAIL=AlmaU Syllabus <noreply@example.com>
EMAIL_TIMEOUT=15

# AI / worker (remote-first by default)
LLM_PROVIDER=remote
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_REMOTE_MODEL=gpt-4o-mini
LLM_REMOTE_TIMEOUT=30
AI_CHECK_LLM_MAX_TOKENS=220
AI_CHECK_LLM_TEMPERATURE=0.1
AI_CHECK_MAX_INPUT_CHARS=5000
AI_CHECK_HEAD_CHARS=2200
AI_CHECK_MIDDLE_CHARS=900
AI_CHECK_TAIL_CHARS=2200
AI_CHECK_FAST_RULES=true
AI_CHECK_PDF_FAST_EXTRACTION=true
AI_WORKER_IDLE_SLEEP=1.0

# Production security
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_X_FRAME_OPTIONS=DENY

# Diagnostics
DIAGNOSTICS_ENV_KEYS=DJANGO_SECRET_KEY,DATABASE_URL
