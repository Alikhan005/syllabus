# Пример настроек Windows Server для дипломного односерверного развертывания.
# Используется SQLite, чтобы совпадать с текущей настройкой сервера.

DJANGO_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY
DJANGO_DEBUG=False

DJANGO_ALLOWED_HOSTS=89.218.8.107,127.0.0.1,localhost
ALLOWED_HOSTS=89.218.8.107,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://89.218.8.107:8000
CSRF_TRUSTED_ORIGINS=http://89.218.8.107:8000

# Это развертывание напрямую обслуживается по HTTP на порту 8000.
# HTTPS-only настройки выключены, пока приложение не стоит за HTTPS.
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

DJANGO_USE_DATABASE_URL=False
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=C:\projects\syllabus\db.sqlite3

DJANGO_MEDIA_ROOT=C:\projects\syllabus\media
DJANGO_SERVE_MEDIA=True

# Замените на реальные SMTP-настройки, если нужны восстановление пароля и настоящая отправка писем.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Режим AI: перед включением укажите LLM_API_KEY в настоящем .env.
AI_CHECK_USE_LLM=True
LLM_PROVIDER=remote
LLM_API_KEY=
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
LLM_REMOTE_MODEL=gemini-2.5-flash
