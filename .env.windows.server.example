# Windows Server example for a single-node diploma deployment.
# Uses SQLite to match the current server setup.

DJANGO_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY
DJANGO_DEBUG=False

DJANGO_ALLOWED_HOSTS=89.218.8.107,127.0.0.1,localhost
ALLOWED_HOSTS=89.218.8.107,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://89.218.8.107:8000
CSRF_TRUSTED_ORIGINS=http://89.218.8.107:8000

DJANGO_USE_DATABASE_URL=False
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=C:\projects\syllabus\db.sqlite3

DJANGO_MEDIA_ROOT=C:\projects\syllabus\media
DJANGO_SERVE_MEDIA=True

# Change to real SMTP settings if you want password reset / real email delivery.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# AI mode: keep rules-based checks by default.
AI_CHECK_USE_LLM=False
